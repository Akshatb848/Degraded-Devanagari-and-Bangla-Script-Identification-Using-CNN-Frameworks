# EXAMPLE ONLY - Do NOT commit actual secrets to git.
# Create this file locally and apply with: kubectl apply -f k8s/secrets.yaml
#
# Encode values: echo -n "your-value" | base64

apiVersion: v1
kind: Secret
metadata:
  name: aiocr-secrets
  namespace: aiocr
type: Opaque
data:
  SECRET_KEY: <base64-encoded-secret-key>
  DATABASE_URL: <base64-encoded-db-url>
  REDIS_URL: <base64-encoded-redis-url>
  CELERY_BROKER_URL: <base64-encoded-celery-broker-url>
  CELERY_RESULT_BACKEND: <base64-encoded-celery-backend-url>
  ANTHROPIC_API_KEY: <base64-encoded-anthropic-key>
  OPENAI_API_KEY: <base64-encoded-openai-key>
  CHROMA_HOST: <base64-encoded-chroma-host>
